{
  "name": "statcode-mcp-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,hono -c cyan,green \"npm run dev:vite\" \"npm run dev:server\"",
    "dev:vite": "vite",
    "dev:server": "tsx watch src/server.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "@hono/mcp": "^0.2.5",
    "@hono/node-server": "^1.13.8",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "hono": "^4.7.5",
    "react-router-dom": "^7.18.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
